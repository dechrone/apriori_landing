# ─── Supabase (auth + app data) ───────────────────────────────────────────────
# Project dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Project dashboard → Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project dashboard → Settings → API → service_role key (SERVER-SIDE ONLY)
# Used by src/lib/supabase/admin.ts — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Simulation backend (FastAPI) ─────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# Some legacy callers still read NEXT_PUBLIC_API_URL; keep it pointing at the
# same backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Asset uploads — go through the FastAPI backend, which talks to Supabase ─
# Storage. The frontend never holds a service-role key; it just renders the
# public CDN URLs the backend returns.
